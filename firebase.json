{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300" }
        ]
      }
    ],
    "cleanUrls": true
  }
}
